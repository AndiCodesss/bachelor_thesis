__pycache__/
*.py[cod]
.pytest_cache/
.venv/
backend/.venv/
# backend/data holds private runtime session data (events/, sessions/,
# interpretation/) which stays local. Tracked by name below: the labelled
# dataset the thesis was built on and the stored result artifacts the thesis
# reads, so the published repo is inspectable and rerunnable.
backend/data/*
!backend/data/training_data.jsonl
!backend/data/training_data_clean.jsonl
!backend/data/training_data_flagged.jsonl
!backend/data/misclassified.json
!backend/data/analysis_results.json
!backend/data/benchmark_results.json
!backend/data/cleanup_report.json
!backend/data/fullstream_eval.json
!backend/data/fullstream_review.md
!backend/data/fullstream_review_context.md
!backend/data/fullstream_review_verdicts.json
!backend/data/pipeline_eval.json
!backend/data/pipeline_review.md
!backend/data/pipeline_review_verdicts.json
!backend/data/fire_context_sheet.md
!backend/data/build_fire_context.py
!backend/data/score_fire_verdicts.py
backend/*.egg-info/
frontend/node_modules/
frontend/dist/
.env
.DS_Store
.claude/
transcripts_new/
# Track exactly the 103 transcripts the thesis dataset was built from
# (including the five held-out full-stream test sessions). Anything else in
# transcripts/ (newer or unused recordings, download manifests) stays local.
transcripts/*
