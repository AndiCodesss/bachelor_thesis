# Word/Office temporary lock files (e.g. ~$MyThesisStructure.docx)
~$*

# Local university-submission PDFs (e.g. the Turnitin/AI-detection report copy).
# The repo tracks texfiles/MyThesisStructure.pdf as the canonical thesis build.
texfiles/bachelor_thesis_*.pdf

# Word exports stay local; the PDF is the only thesis output kept in the repo.
texfiles/*.docx

# LaTeX build artifacts
texfiles/*.aux
texfiles/*.bbl
texfiles/*.blg
texfiles/*.lof
texfiles/*.log
texfiles/*.lot
texfiles/*.out
texfiles/*.toc
texfiles/*.fls
texfiles/*.fdb_latexmk
texfiles/*.synctex.gz
